---
import { FastForward, Loader2, Pause, Play } from "lucide-astro";

interface Props {
  images: string[];
  id: string;
}

const { images, id } = Astro.props;
---

<div class="player-container relative w-full max-w-5xl mx-auto bg-black rounded-xl overflow-hidden shadow-2xl ring-1 ring-white/10" data-images={JSON.stringify(images)} id={`player-${id}`}>
  <!-- Loading Overlay -->
  <div class="loading-overlay absolute inset-0 bg-black/90 backdrop-blur-sm flex flex-col items-center justify-center z-20 text-white transition-opacity duration-500">
    <div class="relative mb-4">
        <Loader2 class="w-12 h-12 animate-spin text-amber-500" />
    </div>
    <div class="text-xl font-medium tracking-wide mb-2">Loading Timelapse</div>
    <div class="progress-bar w-64 h-2 bg-gray-800 rounded-full overflow-hidden">
        <div class="progress-fill h-full bg-amber-500 w-0 transition-all duration-300"></div>
    </div>
    <div class="progress-text text-sm text-gray-400 mt-2 font-mono">0%</div>
  </div>

  <!-- Display Area -->
  <div class="display-area w-full aspect-video flex items-center justify-center bg-zinc-950 relative group">
    <img
      src={images[0]}
      alt="Time lapse frame"
      class="current-frame max-w-full max-h-full object-contain"
      transition:name={`img-${id}`}
    />

    <!-- Big Play Button Overlay -->
    <button class="big-play-btn absolute inset-0 flex items-center justify-center bg-black/30 opacity-0 group-hover:opacity-100 transition-opacity duration-300 focus:opacity-100">
        <div class="p-4 bg-white/10 backdrop-blur-md rounded-full hover:bg-white/20 hover:scale-110 transition-all">
            <Play class="w-12 h-12 text-white fill-white" />
        </div>
    </button>
  </div>

  <!-- Controls -->
  <div class="controls flex items-center gap-4 p-4 bg-zinc-900/95 border-t border-zinc-800 text-gray-100">
    <button class="play-pause-btn p-2 rounded-lg hover:bg-zinc-800 text-amber-500 transition-colors focus:outline-none focus:ring-2 focus:ring-amber-500" aria-label="Play">
      <span class="icon-play block">
        <Play class="w-6 h-6 fill-current" />
      </span>
      <span class="icon-pause hidden">
        <Pause class="w-6 h-6 fill-current" />
      </span>
    </button>

    <div class="flex-1 flex flex-col gap-1">
        <input
            type="range"
            class="timeline-slider w-full h-2 bg-zinc-700 rounded-lg appearance-none cursor-pointer accent-amber-500 hover:accent-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-500/50"
            min="0"
            max={images.length - 1}
            value="0"
            step="1"
        />
        <div class="flex justify-between text-xs text-zinc-500 font-mono">
            <span>START</span>
            <span>END</span>
        </div>
    </div>

    <div class="flex items-center gap-4 pl-4 border-l border-zinc-800">
        <div class="text-sm font-mono text-zinc-400 min-w-[6ch] text-right frame-counter">
            1 / {images.length}
        </div>

        <div class="speed-control flex items-center gap-2">
            <FastForward class="w-4 h-4 text-zinc-500" />
            <select class="speed-select bg-zinc-800 text-zinc-200 text-sm border border-zinc-700 rounded px-2 py-1 focus:outline-none focus:ring-2 focus:ring-amber-500 cursor-pointer hover:bg-zinc-700 transition-colors">
                <option value="1000">1x</option>
                <option value="500">2x</option>
                <option value="250" selected>4x</option>
                <option value="100">10x</option>
                <option value="33">30x</option>
            </select>
        </div>
    </div>
  </div>
</div>

<script>
  class TimeLapsePlayer {
    constructor(container) {
      this.container = container;
      this.imageUrls = JSON.parse(container.dataset.images);
      this.images = []; // Will hold Image objects
      this.currentIndex = 0;
      this.isPlaying = false;
      this.intervalId = null;
      this.fpsDelay = 250;
      this.bufferThreshold = 0.2; // 20%
      this.isReady = false;

      // Elements
      this.imgElement = container.querySelector('.current-frame');
      this.slider = container.querySelector('.timeline-slider');
      this.playBtn = container.querySelector('.play-pause-btn');
      this.bigPlayBtn = container.querySelector('.big-play-btn');
      this.iconPlay = container.querySelector('.icon-play');
      this.iconPause = container.querySelector('.icon-pause');
      this.loadingOverlay = container.querySelector('.loading-overlay');
      this.progressText = container.querySelector('.progress-text');
      this.progressFill = container.querySelector('.progress-fill');
      this.counter = container.querySelector('.frame-counter');
      this.speedSelect = container.querySelector('.speed-select');

      this.init();
    }

    async init() {
      // Bind events
      this.playBtn.addEventListener('click', () => this.togglePlay());
      this.bigPlayBtn.addEventListener('click', () => this.togglePlay());
      this.slider.addEventListener('input', (e) => this.seek(parseInt(e.target.value)));
      this.speedSelect.addEventListener('change', (e) => this.setSpeed(parseInt(e.target.value)));

      // Initialize image array
      this.images = new Array(this.imageUrls.length).fill(null);

      // Start loading
      this.startBufferedLoading();
    }

    startBufferedLoading() {
      let loadedCount = 0;
      const total = this.imageUrls.length;
      const bufferLimit = Math.floor(total * this.bufferThreshold);

      // Prioritize loading initial frames sequentially for smoother start
      // Then load the rest in parallel batches or all at once depending on browser capability

      this.imageUrls.forEach((url, index) => {
        const img = new Image();
        img.src = url;
        img.onload = () => {
            loadedCount++;
            this.images[index] = img;
            this.updateLoadingProgress(loadedCount, total);

            // Check if we hit the buffer threshold to allow playback
            if (!this.isReady && loadedCount >= bufferLimit) {
                this.enablePlayback();
            }

            // If completely loaded
            if (loadedCount === total) {
                this.onLoadComplete();
            }
        };
        img.onerror = () => {
            console.warn(`Failed to load frame ${index}: ${url}`);
            loadedCount++; // Count error as processed to avoid hanging
            this.updateLoadingProgress(loadedCount, total);
        };
      });
    }

    updateLoadingProgress(current, total) {
      const percentage = Math.round((current / total) * 100);
      if (this.progressText) this.progressText.textContent = `${percentage}%`;
      if (this.progressFill) this.progressFill.style.width = `${percentage}%`;
    }

    enablePlayback() {
        this.isReady = true;
        this.loadingOverlay.classList.add('opacity-0', 'pointer-events-none');
        // Optional: Auto-play when ready?
        // this.play();
    }

    onLoadComplete() {
        // Ensure overlay is hidden if it wasn't already
        if (!this.isReady) this.enablePlayback();
    }

    togglePlay() {
      if (!this.isReady) return;

      if (this.isPlaying) {
        this.pause();
      } else {
        this.play();
      }
    }

    play() {
      if (this.currentIndex >= this.images.length - 1) {
        this.currentIndex = 0;
      }
      this.isPlaying = true;
      this.updatePlayIcon();
      this.bigPlayBtn.style.display = 'none';

      this.intervalId = setInterval(() => {
        this.tick();
      }, this.fpsDelay);
    }

    pause() {
      this.isPlaying = false;
      this.updatePlayIcon();
      this.bigPlayBtn.style.display = 'flex';
      clearInterval(this.intervalId);
    }

    tick() {
        if (this.currentIndex < this.images.length - 1) {
            this.currentIndex++;
            this.updateFrame();
        } else {
            this.pause();
        }
    }

    seek(index) {
      this.currentIndex = index;
      this.updateFrame();
    }

    setSpeed(delay) {
      this.fpsDelay = delay;
      if (this.isPlaying) {
        clearInterval(this.intervalId);
        this.intervalId = setInterval(() => this.tick(), this.fpsDelay);
      }
    }

    updateFrame() {
      const imgObj = this.images[this.currentIndex];

      if (imgObj && imgObj.complete) {
        this.imgElement.src = imgObj.src;
      } else {
         // Fallback to URL if Image object isn't ready yet (should be rare with buffering)
         this.imgElement.src = this.imageUrls[this.currentIndex];
      }

      this.slider.value = this.currentIndex;
      this.counter.textContent = `${this.currentIndex + 1} / ${this.images.length}`;
    }

    updatePlayIcon() {
      if (this.isPlaying) {
        this.iconPlay.classList.add('hidden');
        this.iconPause.classList.remove('hidden');
      } else {
        this.iconPlay.classList.remove('hidden');
        this.iconPause.classList.add('hidden');
      }
    }
  }

  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.player-container').forEach(container => {
        new TimeLapsePlayer(container);
    });
  });
</script>
