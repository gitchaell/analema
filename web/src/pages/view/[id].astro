---
import Camera from 'lucide-astro/Camera'
import ChevronLeft from 'lucide-astro/ChevronLeft'
import MapPin from 'lucide-astro/MapPin'
import Player from '../../components/Player.astro'
import manifest from '../../data/manifest.json'
import Layout from '../../layouts/Layout.astro'

export function getStaticPaths() {
	return manifest.map((item) => ({
		params: { id: item.id },
		props: { item },
	}))
}

const { item } = Astro.props
---

<Layout title={`${item.location} - ${item.object} - ${item.camera}`}>
	<div class="max-w-6xl mx-auto">
		<div class="mb-6 flex items-center justify-between">
			<a
				href="/"
				class="flex items-center gap-2 text-gray-500 hover:bg-gray-200 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-zinc-800 dark:hover:text-gray-100 px-3 py-1.5 rounded-lg transition-all active:scale-95 font-medium -ml-3"
			>
				<ChevronLeft class="w-5 h-5" />
				Back to Gallery
			</a>
			<span class="text-xs font-mono text-gray-400 dark:text-zinc-600   hidden sm:block"
				>{item.id}</span
			>
		</div>

		<div
			class="bg-white dark:bg-zinc-800 rounded-2xl shadow-sm border border-gray-200 dark:border-zinc-700 p-6 mb-8"
		>
			<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-6">
				<div>
					<h1
						class="font-heading text-4xl font-bold text-gray-900 dark:text-white mb-2 tracking-tight"
					>
						{item.location.split('-').slice(2).join(' ').replace(/\b\w/g, l => l.toUpperCase())}
					</h1>
					<div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
						<div class="flex items-center gap-1.5">
							<MapPin class="w-4 h-4" />
							<span class=" ">{item.location.split('-')[1]}</span>
						</div>
						<div class="w-px h-4 bg-gray-300 dark:bg-zinc-600"></div>
						<div class="flex items-center gap-1.5">
							<Camera class="w-4 h-4" />
							<span>{item.camera}</span>
						</div>
					</div>
				</div>

				<span
					class={`px-3 py-1 rounded-full text-sm font-bold   self-start md:self-auto ${
          item.object === 'sun'
            ? 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-500'
            : 'bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400'
        }`}
				>
					{item.object}
				</span>
			</div>

			<Player images={item.images} id={item.id} preview={item.preview} />

			<div class="mt-6 text-sm text-gray-500 dark:text-zinc-500 text-center font-mono">
				Sequence contains {item.count} captured frames
			</div>
		</div>
	</div>
</Layout>
