---
import Camera from 'lucide-astro/Camera'
import ChevronDown from 'lucide-astro/ChevronDown'
import MapPin from 'lucide-astro/MapPin'
import Search from 'lucide-astro/Search'
import manifest from '../data/manifest.json'
import Layout from '../layouts/Layout.astro'

const locations = [...new Set(manifest.map((item) => item.location))]
const objects = [...new Set(manifest.map((item) => item.object))]
const cameras = [...new Set(manifest.map((item) => item.camera))]
---

<Layout title="Analemma Captures Viewer">
	<div class="mb-8">
		<div
			class="flex flex-col md:flex-row gap-4 justify-between items-center bg-white dark:bg-zinc-800 p-4 rounded-xl shadow-sm border border-gray-200 dark:border-zinc-700"
		>
			<div class="flex items-center gap-2 text-gray-500 dark:text-gray-400">
				<Search class="w-5 h-5" />
				<span class="font-medium">Filters</span>
			</div>

			<div class="flex flex-wrap gap-4 w-full md:w-auto">
				<!-- Location Filter -->
				<div class="relative inline-flex items-center">
					<select
						id="filter-location"
						class="appearance-none px-4 py-2 pr-8 rounded-xl bg-gray-50 dark:bg-zinc-900 border border-gray-200 dark:border-zinc-700 text-sm focus:ring-2 focus:ring-green-400 outline-none cursor-pointer hover:bg-gray-100 dark:hover:bg-zinc-800 transition-colors"
					>
						<option value="all">All Locations</option>
						{locations.map((loc) => (
								<option value={loc}>
									{loc
										.split("-")
										.slice(2)
										.join(" ")
										.replace(/\b\w/g, (l) => l.toUpperCase())}
								</option>
							))}
					</select>
					<ChevronDown
						class="absolute right-2.5 w-4 h-4 text-gray-500 dark:text-gray-400 pointer-events-none"
					/>
				</div>

				<!-- Object Filter -->
				<div class="relative inline-flex items-center">
					<select
						id="filter-object"
						class="appearance-none px-4 py-2 pr-8 rounded-xl bg-gray-50 dark:bg-zinc-900 border border-gray-200 dark:border-zinc-700 text-sm focus:ring-2 focus:ring-green-400 outline-none cursor-pointer hover:bg-gray-100 dark:hover:bg-zinc-800 transition-colors"
					>
						<option value="all">All Objects</option>
						{objects.map((obj) => (
								<option value={obj}>
									{obj.charAt(0).toUpperCase() + obj.slice(1)}
								</option>
							))}
					</select>
					<ChevronDown
						class="absolute right-2.5 w-4 h-4 text-gray-500 dark:text-gray-400 pointer-events-none"
					/>
				</div>

				<!-- Camera Filter -->
				<div class="relative inline-flex items-center">
					<select
						id="filter-camera"
						class="appearance-none px-4 py-2 pr-8 rounded-xl bg-gray-50 dark:bg-zinc-900 border border-gray-200 dark:border-zinc-700 text-sm focus:ring-2 focus:ring-green-400 outline-none cursor-pointer hover:bg-gray-100 dark:hover:bg-zinc-800 transition-colors"
					>
						<option value="all">All Cameras</option>
						{cameras.map((cam) => <option value={cam}>{cam}</option>)}
					</select>
					<ChevronDown
						class="absolute right-2.5 w-4 h-4 text-gray-500 dark:text-gray-400 pointer-events-none"
					/>
				</div>
			</div>
		</div>
	</div>

	<div
		id="grid-container"
		class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"
	>
		{manifest.map((item) => (
				<a
					href={`/view/${item.id}`}
					class="grid-item group block bg-white dark:bg-zinc-800 rounded-xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-200 dark:border-zinc-700"
					data-location={item.location}
					data-object={item.object}
					data-camera={item.camera}
				>
					<div class="aspect-video bg-black overflow-hidden relative">
						<img
							src={item.preview}
							alt={`Preview of ${item.id}`}
							loading="lazy"
							class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
							transition:name={`img-${item.id}`}
						/>
						<div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
							<span class="text-white text-xs font-medium px-2 py-1 bg-white/20 backdrop-blur-sm rounded-full">
								View Timelapse &rarr;
							</span>
						</div>
					</div>

					<div class="p-4">
						<h3 class="font-heading font-bold text-xl mb-2 text-gray-900 dark:text-gray-100 line-clamp-1">
							{item.location
								.split("-")
								.slice(2)
								.join(" ")
								.replace(/\b\w/g, (l) => l.toUpperCase())}
						</h3>

						<div class="flex items-center justify-between text-sm text-gray-500 dark:text-gray-400 mb-3">
							<div class="flex items-center gap-1.5">
								<MapPin class="w-3.5 h-3.5" />
								<span class="truncate max-w-25">
									{item.location.split("-")[1].toUpperCase()}
								</span>
							</div>
							<div class="flex items-center gap-1.5">
								<Camera class="w-3.5 h-3.5" />
								<span>{item.camera}</span>
							</div>
						</div>

						<div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100 dark:border-zinc-700">
							<span
								class={`px-2.5 py-0.5 rounded-full text-xs font-bold   ${
									item.object === "sun"
										? "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-500"
										: "bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400"
								}`}
							>
								{item.object}
							</span>
							<span class="text-xs font-mono text-gray-400">
								{item.count} frames
							</span>
						</div>
					</div>
				</a>
			))}
	</div>

	<div id="no-results" class="hidden py-20 text-center text-gray-500 dark:text-gray-400">
		<p class="text-lg">No captures found matching your filters.</p>
		<button
			id="clear-filters"
			type="button"
			class="mt-4 text-amber-600 dark:text-green-400 hover:underline"
		>
			Clear all filters
		</button>
	</div>
</Layout>

<script>
function initFilters() {
	const filters = {
		location: document.getElementById('filter-location') as HTMLSelectElement,
		object: document.getElementById('filter-object') as HTMLSelectElement,
		camera: document.getElementById('filter-camera') as HTMLSelectElement,
	}

	const gridContainer = document.getElementById('grid-container')
	const items = document.querySelectorAll('.grid-item')
	const noResults = document.getElementById('no-results')
	const clearBtn = document.getElementById('clear-filters')

	function applyFilters() {
		if (!filters.location || !filters.object || !filters.camera) return

		const selectedLocation = filters.location.value
		const selectedObject = filters.object.value
		const selectedCamera = filters.camera.value

		let visibleCount = 0

		items.forEach((item) => {
			const el = item as HTMLElement
			const loc = el.dataset.location
			const obj = el.dataset.object
			const cam = el.dataset.camera

			const matchLocation = selectedLocation === 'all' || loc === selectedLocation
			const matchObject = selectedObject === 'all' || obj === selectedObject
			const matchCamera = selectedCamera === 'all' || cam === selectedCamera

			if (matchLocation && matchObject && matchCamera) {
				el.style.display = 'block'
				visibleCount++
			} else {
				el.style.display = 'none'
			}
		})

		if (noResults && gridContainer) {
			if (visibleCount === 0) {
				noResults.classList.remove('hidden')
				gridContainer.classList.add('hidden')
			} else {
				noResults.classList.add('hidden')
				gridContainer.classList.remove('hidden')
			}
		}
	}

	Object.values(filters).forEach((select) => {
		select?.addEventListener('change', applyFilters)
	})

	clearBtn?.addEventListener('click', () => {
		if (filters.location) filters.location.value = 'all'
		if (filters.object) filters.object.value = 'all'
		if (filters.camera) filters.camera.value = 'all'
		applyFilters()
	})
}

// Re-run on View Transitions navigation
document.addEventListener('astro:page-load', initFilters)
</script>
